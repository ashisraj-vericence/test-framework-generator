name: playwright-e2e-framework-ci
on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]
jobs:
  test:
    timeout-minutes: 60
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: lts/*
      - name: Install dependencies
        run: npm ci
      - name: Run typecheck and lint
        run: npm run check
      - name: Check formatting (Prettier)
        run: |
          npm run prettier-fix
          git diff --exit-code || (echo "Prettier changed files; run 'npm run prettier-fix' and commit." && exit 1)
      <% if (['web', 'hybrid'].includes(preset)) { %>
      - name: Install Playwright Browsers
        run: npx playwright install --with-deps
      <% } %>
      - name: Run Playwright tests
        run: npm run test:runner:dev
      <% if (reporter === "html") { %>
      - name: Upload test artifacts
        uses: actions/upload-artifact@v4
        if: ${{ !cancelled() }}
        with:
          name: playwright-report
          path: artifacts/reports/html-reports/
          retention-days: 30
      <% } else if (reporter === "monocart") { %>
      - name: Upload Monocart Report
        uses: actions/upload-artifact@v4
        if: ${{ !cancelled() }}
        with:
          name: monocart-report
          path: artifacts/reports/monocart-report/
          retention-days: 30
      <% } else if (reporter === "allure") { %>
      - name: Upload Allure Report
        uses: actions/upload-artifact@v4
        if: ${{ !cancelled() }}
        with:
          name: allure-report
          path: artifacts/reports/allure-report/
          retention-days: 30
      <% } %>
