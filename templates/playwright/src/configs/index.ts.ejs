import { loadDotenvIfPresent } from '@utils';
import { DotenvFlowParseResult } from 'dotenv-flow';
import defaultConfig from './default';
import localConfig from './dev';
import qaConfig from './qa';
import stagingConfig from './stage';
import { FrameworkConfig } from './types';

export function getConfig(): FrameworkConfig {
  // load corresponding .env file if present (e.g. .env.qa for 'qa' env)
  const dotEnv = loadDotenvIfPresent();
  const dotEnvParsed: Partial<DotenvFlowParseResult | undefined> = dotEnv?.parsed || {};

  const partials: Partial<FrameworkConfig> =
    dotEnvParsed!['ENV'] === 'qa' ? qaConfig : dotEnvParsed!['ENV'] === 'stage' ? stagingConfig : localConfig;

  const merged: FrameworkConfig = {
    ...defaultConfig,
    ...partials,
    envName: dotEnvParsed!['ENV'],
    dotEnv: dotEnvParsed,
  } as FrameworkConfig;

  return merged;
}

export default getConfig;

export * from './types';
