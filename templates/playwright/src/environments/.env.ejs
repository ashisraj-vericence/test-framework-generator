<%
  const isWebPreset = ['web', 'hybrid'].includes(preset);
  const isApiPreset = ['api', 'hybrid'].includes(preset);
  const isSoapPreset = ['soap', 'hybrid'].includes(preset);
%>
PROJECT_NAME=<%= projectName %>

<% if (isWebPreset) { %>
BASE_URL=https://www.saucedemo.com/
APP_BASE_URL=https://www.saucedemo.com/

USER_NAME=standard_user
USER_PASSWORD=secret_sauce

# Auth mode switch (FORM | SESSION)
AUTH_MODE=FORM

STORAGE_STATE=

<% } %>

<% if (isApiPreset) { %>
API_BASE_URL=http://localhost:3000/
USE_MOCK_APOLLO=true
<% } %>

<% if (isSoapPreset) { %>
CALC_SOAP_WSDL_URL=http://www.dneonline.com/calculator.asmx
COUNTRY_SOAP_WSDL_URL=http://webservices.oorsprong.org/websamples.countryinfo/CountryInfoService.wso
NUMBER_CONVERSION_SOAP_WSDL_URL=https://www.dataaccess.com/webservicesserver/NumberConversion.wso
<% } %>

# Email Notifications
NOTIFY_EMAIL=false
EMAIL_FROM=
EMAIL_TO=

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=txsp...
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=false

# Slack Notifications
NOTIFY_SLACK=false
SLACK_TOKEN=xoxe.xoxp-1-T...    # bot token with chat:write scope
SLACK_CHANNEL=C0A4...  # channel ID (not the name)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0A0G.../B0A5K.../5VgFE...

# Teams Notifications
TEAMS_WEBHOOK_URL=
NOTIFY_TEAMS=false

LOG_LEVEL=INFO

# allure|monocart|html|tta
DEFAULT_REPORTER=<%= reporter %>

OPEN_TEST_REPORT=true
