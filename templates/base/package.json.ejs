{
  "name": "<%= projectName %>",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    <% if (['api', 'hybrid'].includes(preset)) { %>
    "start": "ts-node ./src/utils/server.ts",
    <% } %>
    <% const bddPrefix = (framework === 'playwright-bdd') ? 'npx bddgen && ' : ''; %>
    "test:runner:dev": "npm run reports:clean && <%- bddPrefix %>tsx src/utils/test-runner.ts --env dev --grep @regression",
    "test:runner:ui:dev": "npm run reports:clean && <%- bddPrefix %>tsx src/utils/test-runner.ts --env dev --ui",
    "test:dev": "npm run reports:clean && <%- bddPrefix %> npx cross-env NODE_ENV=dev playwright test --grep @regression",
    "test:dev:ui": "npm run reports:clean && <%- bddPrefix %> npx cross-env NODE_ENV=dev playwright test --ui",
    "prettier-fix": "prettier -w . --ignore-pattern .prettierignore",
    "lint": "eslint . --fix --max-warnings 0 --no-cache",
    <% if (framework === 'playwright-bdd') { %>
    "lint:gherkin": "npx gherkin-lint  --config .gherkin-lintrc --format stylish features",
    <% } %>
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "logs:clean": "rimraf --glob artifacts/logs/*",
    "reports:clean": "rimraf --glob artifacts/reports/*"<% if (notifications === true) { %>,
    "notify-report": "tsx src/tools/notifications/notifications.ts --env dev --email True --slack True",
    "run-and-notify": "npm run test:runner:headed && npm run notify-report"
    <% } %>
  }
}
